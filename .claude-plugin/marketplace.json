{
  "name": "plem-marketplace",
  "owner": {
    "name": "WIM Corporation"
  },
  "metadata": {
    "description": "plem Claude Code plugin marketplace",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "plem-init",
      "source": "./plugins/plem-init",
      "description": "plem 기반 로봇 프로젝트 초기화 위자드",
      "version": "1.0.1"
    },
    {
      "name": "zed-sdk",
      "source": "./plugins/zed-sdk",
      "description": "ZED SDK 공식 문서 레퍼런스 (카메라 API, 깊이 센싱, 객체 탐지, ROS 2, YOLO)",
      "version": "1.0.1"
    },
    {
      "name": "ros-docs",
      "source": "./plugins/ros-docs",
      "description": "ROS 2 공식 문서 기반 레퍼런스",
      "version": "1.0.0"
    }
  ]
}
